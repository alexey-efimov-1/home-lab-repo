[Unit]
Description=Apache Kafka Server (KRaft)
Documentation=http://kafka.apache.org/documentation.html
Requires=network.target
After=network.target

[Service]
Type=simple
User={{ kafka_user }}
Group={{ kafka_group }}
Environment=JAVA_HOME=/usr/lib/jvm/java-17-openjdk-amd64
ExecStart={{ kafka_install_dir }}/bin/kafka-server-start.sh {{ kafka_install_dir }}/config/server.properties
ExecStop={{ kafka_install_dir }}/bin/kafka-server-stop.sh
Restart=on-failure
RestartSec=5
TimeoutStopSec=180

# Ограничения ресурсов для домашней ВМ
LimitNOFILE=100000

[Install]
WantedBy=multi-user.target